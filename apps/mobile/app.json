{
  "expo": {
    "name": "NookMe",
    "slug": "nookme",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "nookme",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "xyz.nookme.app",
      "infoPlist": {
        "NSCameraUsageDescription": "NookMe needs camera access to share photos.",
        "NSPhotoLibraryUsageDescription": "NookMe needs photo library access to share images.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "xyz.nookme.app",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "nookme.xyz",
              "pathPrefix": "/nook"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-router",
        {
          "root": "./app"
        }
      ],
      "expo-font",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsText": true
          }
        }
      ]
    ],
    "extra": {
      "router": {
        "root": "./app"
      },
      "eas": {
        "projectId": "15ad053c-c1a6-4c2d-a5fc-9e4babec3ca0"
      }
    }
  }
}
